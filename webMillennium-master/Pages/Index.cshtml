<!-- Contato -->
<section class="contato-section" id="contato">
    <div class="contato-inner">
        <div class="contato-info reveal-on-scroll">
            <h2 class="section-title">Fale conosco</h2>
            <p class="section-lead">
                Solicite informações, demonstração ou planos. Estamos prontos para ajudar.
            </p>
            <div class="contato-canais">
                <p><strong>Celular:</strong> (28) 99935-8301 - (28) 99916-6075</p>
                <p><strong>WhatsApp:</strong> (28) 99935-8301 - (28) 99916-6075</p>
                <p><strong>E-mail comercial:</strong> contato@millenniumti.com.br</p>
            </div>
        </div>
        <div class="reveal-on-scroll">
            <form id="form-contato" class="contato-form" method="post" aria-label="Formulário de contato">
                <label for="nome">Nome</label>
                <input id="nome" name="nome" type="text" required placeholder="Seu nome" />
                <label for="email">E-mail</label>
                <input id="email" name="email" type="email" required placeholder="seu@email.com" />
                <label for="telefone">Telefone</label>
                <input id="telefone" name="telefone" type="tel" placeholder="(00) 00000-0000" />
                <label for="empresa">Empresa</label>
                <input id="empresa" name="empresa" type="text" placeholder="Nome da empresa" />
                <label for="mensagem">Mensagem</label>
                <textarea id="mensagem" name="mensagem" rows="4" placeholder="Como podemos ajudar?"></textarea>
                <button type="submit" class="btn btn-primary">Enviar mensagem</button>
            </form>
        </div>
    </div>
</section>
