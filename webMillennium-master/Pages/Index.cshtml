<!-- Hero -->
<section class="hero" id="home">
    <div class="hero-content">
        <h1 class="hero-title">
            <span class="hero-title-line">SUA EMPRESA SEGURA,</span>
            <span class="hero-title-line gradient-text">ESTÁVEL E PREPARADA </span>
            <span class="hero-title-line gradient-text">PARA CRESCER</span>
        </h1>
        <p class="hero-subtitle">
            @* Plataforma web para gestão de atendimentos e relacionamento com clientes. Controle centralizado por empresa, com acompanhamento em tempo real. *@
            Especialistas em redes, segurança e criação de ecossistemas web de alto impacto para empresas visionárias
        </p>
        <div class="hero-buttons">
            <a href="https://api.whatsapp.com/send/?phone=5528999358301&text&type=phone_number&app_absent=0" class="btn btn-primary"><i class="fa fa-whatsapp"></i>  Solicitar contato</a>
            <a href="#solucoes" class="btn btn-outline">Conhecer soluções</a>
        </div>
    </div>
    <div class="hero-image">
        <div class="floating-card">
            <div class="dashboard-mock">
                <div class="dashboard-mock-header">
                    <span class="dashboard-mock-title"><i class="fa fa-server"></i> Status do Sistema</span>
                    <span class="dashboard-mock-badge"><i class="fa fa-circle dashboard-live-dot"></i> Tempo real</span>
                </div>
                <div class="dashboard-mock-kpis">
                    <div class="dashboard-kpi">
                        <span class="dashboard-kpi-value">99.9%</span>
                        <span class="dashboard-kpi-label">Uptime</span>
                    </div>
                    <div class="dashboard-kpi">
                        <span class="dashboard-kpi-value">2.4k</span>
                        <span class="dashboard-kpi-label">Ameaças</span>
                    </div>
                    <div class="dashboard-kpi">
                        <span class="dashboard-kpi-value">24/7</span>
                        <span class="dashboard-kpi-label">Monitorado</span>
                    </div>
                    <div class="dashboard-kpi">
                        <span class="dashboard-kpi-value">58</span>
                        <span class="dashboard-kpi-label">Sites</span>
                    </div>
                </div>
                <div class="dashboard-mock-chart">
                    <div class="dashboard-chart-bar" style="--h: 45%"></div>
                    <div class="dashboard-chart-bar" style="--h: 70%"></div>
                    <div class="dashboard-chart-bar" style="--h: 55%"></div>
                    <div class="dashboard-chart-bar" style="--h: 90%"></div>
                    <div class="dashboard-chart-bar" style="--h: 65%"></div>
                    <div class="dashboard-chart-bar" style="--h: 80%"></div>
                </div>
                <div class="dashboard-mock-activity">
                    <div class="dashboard-activity-item"><i class="fa fa-check-circle"></i> Backup diário concluído</div>
                    <div class="dashboard-activity-item"><i class="fa fa-clock-o"></i> Firewall atualizado</div>
                    <div class="dashboard-activity-item"><i class="fa fa-plus-circle"></i> Certificado SSL renovado</div>
                </div>
            </div>
        </div>
    </div>
</section>
